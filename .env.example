# Lattice Agent Configuration (Python)

# Active LLM Provider: 'gemini' | 'openai' | 'ollama'
LLM_PROVIDER=gemini

# Provider API Keys
GEMINI_API_KEY=
OPENAI_API_KEY=

# Model Names
GEMINI_MODEL=gemini-2.5-flash
OPENAI_MODEL=gpt-4o-mini

# Local Ollama Configurations
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3

# Serper or Tavily Search API Key (optional - DDG HTML scraping fallback included)
SEARCH_API_KEY=

# Gateway: 'terminal' | 'whatsapp'
GATEWAY=terminal

# Twilio WhatsApp API Credentials (optional for outgoing WhatsApp tool/gateway)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Agent parameters
MAX_STEPS=10
JACCARD_THRESHOLD=0.7

